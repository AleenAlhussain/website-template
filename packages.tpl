{include file='_head.tpl'}
{include file='_header.tpl'}

<style>
	body {
		background-color: #fff;
	}
	.main-wrapper {
		padding-right: 90px;
		padding-left: 0;
	}
	.ele_sidebar_left {
		display: none;
	}
	@media (max-width: 1200px) {
	.main-wrapper {
		padding: 0;
	}
	}
</style>

{if $view == "packages"}
	
	<!-- page content -->
	<div class="pb-5 mt-n5 ele_pro_page">
		<div class="container">
			<!-- page header -->
			<div class="mt-5 pt-5 pb-4 ele_pro_head">
				<p class="m-0 text-uppercase">{$system['system_title']} <span class="badge mt-n1">{__("Pro")}</span></p>
				<h2 class="mb-0">{__("Pro Packages")}. {__("Choose the Plan That's Right for You")}.</h2>
			</div>
			<!-- page header -->
			
			{if $highlight}
				<div class="alert alert-warning">
					{__("To unlock this feature, you need to upgrade to a Pro package")}
				</div>
            {/if}

			<div class="row mx-lg-n4">
				{foreach $packages as $package}
					<!-- package -->
					<div class="col-md-12 col-lg-6 px-lg-4">
						<div class="ele_content rounded-0 shadow-none mt-5 position-relative ele_pro_plan" style="color: {$package['color']}">
							<div class="position-relative ele_pro_plan_head">
								<h3 class="valign">
									{__($package['name'])}&nbsp;&nbsp;
									<span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-white mt-n1"><img src="{$package['icon']}"></span>
								</h3>
								{if $package['custom_description']}
									<p class="mt-1 mb-0">
										{__($package['custom_description'])|nl2br}
									</p>
								{/if}
							</div>
							<div class="position-relative valign ele_pro_plan_price">
								<h3>
									{if $package['price'] == 0}
										{__("Free")}
									{else}
										{print_money($package['price'])}
									{/if}
								</h3>&nbsp;&nbsp;
								<span class="bold">
									{if $package['period'] == "life"}
										{__("Life Time")}
									{else}
										{__("for")} 
										{if $package['period_num'] != '1'}{$package['period_num']}{/if} {__($package['period']|ucfirst)}
									{/if}
								</span>
							</div>
							<div class="row ele_pro_plan_info">
								<div class="col-md-6 mb-2">
									<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" class="align-text-top"><path d="M12 2C6.49 2 2 6.49 2 12C2 17.51 6.49 22 12 22C17.51 22 22 17.51 22 12C22 6.49 17.51 2 12 2ZM16.78 9.7L11.11 15.37C10.97 15.51 10.78 15.59 10.58 15.59C10.38 15.59 10.19 15.51 10.05 15.37L7.22 12.54C6.93 12.25 6.93 11.77 7.22 11.48C7.51 11.19 7.99 11.19 8.28 11.48L10.58 13.78L15.72 8.64C16.01 8.35 16.49 8.35 16.78 8.64C17.07 8.93 17.07 9.4 16.78 9.7Z"/></svg>&nbsp;&nbsp;{__("Featured member")}
